// wifi_credentials.h — copy this file to wifi_credentials.h and fill in your
// network details. wifi_credentials.h is gitignored and must never be committed.
#pragma once
#define WIFI_SSID     "your_network_name"
#define WIFI_PASSWORD "your_password"
// mDNS hostname — device will be reachable as <DEVICE_NAME>.local on the LAN.
// If you have multiple Picos on the same network, give each a unique name.
#define DEVICE_NAME   "pico-leds"
